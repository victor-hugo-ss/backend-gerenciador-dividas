generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  FRIEND
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum DebtStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
}

enum InstallmentStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(OWNER)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relações
  friends     Friend[]
  invitations Invitation[]

  cards     Card[]
  purchases Purchase[]

  ownedAuditLogs AuditLog[] @relation("AuditLogOwner")
  actedAuditLogs AuditLog[] @relation("AuditLogActor")
  debts          Debt[]

  @@index([role])
}

model Friend {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id])

  name     String
  phone    String?
  notes    String?
  isActive Boolean @default(true)

  invitations Invitation[]
  purchases   Purchase[]
  debts       Debt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Invitation {
  id       String @id @default(uuid()) @db.Uuid
  ownerId  String @db.Uuid
  friendId String @db.Uuid

  owner  User   @relation(fields: [ownerId], references: [id])
  friend Friend @relation(fields: [friendId], references: [id])

  token     String           @unique
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  sentAt     DateTime  @default(now())
  acceptedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([friendId])
  @@index([status])
}

model Card {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id])

  name       String
  brand      String?
  limit      Decimal? @db.Decimal(12, 2)
  closingDay Int
  dueDay     Int
  isActive   Boolean  @default(true)

  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Purchase {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id])

  cardId String @db.Uuid
  card   Card   @relation(fields: [cardId], references: [id])

  friendId String @db.Uuid
  friend   Friend @relation(fields: [friendId], references: [id])

  description  String
  purchaseDate DateTime
  totalAmount  Decimal  @db.Decimal(12, 2)
  installments Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  debt Debt?

  @@index([ownerId])
  @@index([cardId])
  @@index([friendId])
}

model Debt {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id])

  purchaseId String   @unique @db.Uuid
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  friendId String @db.Uuid
  friend   Friend @relation(fields: [friendId], references: [id])

  originalAmount Decimal    @db.Decimal(12, 2)
  currentBalance Decimal    @db.Decimal(12, 2)
  status         DebtStatus @default(OPEN)

  installments DebtInstallment[]
  payments     Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([friendId])
  @@index([status])
}

model DebtInstallment {
  id     String @id @default(uuid()) @db.Uuid
  debtId String @db.Uuid
  debt   Debt   @relation(fields: [debtId], references: [id])

  number  Int
  amount  Decimal           @db.Decimal(12, 2)
  dueDate DateTime
  status  InstallmentStatus @default(OPEN)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([debtId, number])
  @@index([debtId])
  @@index([status])
}

model Payment {
  id     String @id @default(uuid()) @db.Uuid
  debtId String @db.Uuid
  debt   Debt   @relation(fields: [debtId], references: [id])

  installmentId String?          @db.Uuid
  installment   DebtInstallment? @relation(fields: [installmentId], references: [id])

  amount Decimal  @db.Decimal(12, 2)
  paidAt DateTime
  note   String?

  createdAt DateTime @default(now())

  @@index([debtId])
  @@index([installmentId])
}

model AuditLog {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation("AuditLogOwner", fields: [ownerId], references: [id])

  actorUserId String @db.Uuid
  actor       User   @relation("AuditLogActor", fields: [actorUserId], references: [id])

  action     String
  entityType String
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([actorUserId])
  @@index([entityType, entityId])
}
